---
import { siteData } from '../data/site';

interface Props {
  inverted?: boolean;
  compact?: boolean;
}

const { inverted = false, compact = false } = Astro.props as Props;
const itemClass = inverted
  ? 'text-white hover:text-brand-gold'
  : 'text-brand-muted hover:text-brand-charcoal';
---

<div class:list={['flex flex-wrap items-center gap-4', compact ? 'text-sm' : 'text-sm sm:text-base']}>
  {siteData.socialLinks.map((link) => (
    <a href={link.href} class={`inline-flex items-center gap-2 ${itemClass}`} target="_blank" rel="noreferrer">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-current/20">
        {link.label === 'Instagram' ? (
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8">
            <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
        ) : link.label === 'Facebook' ? (
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
            <path d="M13.5 21v-7h2.3l.4-2.8h-2.7V9.4c0-.8.2-1.4 1.4-1.4H16V5.5c-.5-.1-1.3-.1-2.1-.1-2.1 0-3.6 1.3-3.6 3.7v2.1H8v2.8h2.2v7h3.3Z"></path>
          </svg>
        ) : (
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
            <path d="M16.64 5.61A5.07 5.07 0 0 1 15.1 2h-3.01v13.07a2.54 2.54 0 1 1-2.54-2.54c.21 0 .41.03.61.08V9.55c-.2-.02-.4-.04-.61-.04A5.55 5.55 0 1 0 15.1 15V8.58A8.02 8.02 0 0 0 20 10.22V7.19a5.04 5.04 0 0 1-3.36-1.58Z"></path>
          </svg>
        )}
      </span>
      <span>
        <span class="font-medium">{link.label}</span>
        {!compact && <span class="ml-1 opacity-80">{link.handle}</span>}
      </span>
    </a>
  ))}
</div>

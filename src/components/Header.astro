---
import { brandAssets } from '../data/site';
import { getSiteData, type Locale, uiText, withLocalePath } from '../lib/i18n';

interface Props {
  locale?: Locale;
  pageTitle?: string;
}

const { locale = 'fr', pageTitle = '' } = Astro.props as Props;
const siteData = getSiteData(locale);
const links = [
  { href: withLocalePath('/', locale), label: uiText[locale].nav.home },
  { href: withLocalePath('/catalogue', locale), label: uiText[locale].nav.catalogue },
  { href: withLocalePath('/a-propos', locale), label: uiText[locale].nav.about },
  { href: withLocalePath('/contact', locale), label: uiText[locale].nav.contact }
];
---

<header class="sticky top-0 z-50 border-b border-brand-line/80 bg-brand-bg/95 backdrop-blur">
  <div class="container-shell py-3">
    <div class="hidden items-center justify-between gap-6 md:flex">
      <a href={withLocalePath('/', locale)} class="flex items-center gap-3">
        <img src={brandAssets.logo} alt={`${siteData.brandName} logo`} class="h-12 w-12 rounded-full object-cover ring-1 ring-brand-gold/35" />
        <div>
          <div class="text-sm font-semibold uppercase tracking-brand text-brand-charcoal">{siteData.brandName}</div>
          <div class="text-xs text-brand-muted">{siteData.tagline}</div>
        </div>
      </a>

      <nav class="flex items-center gap-8">
        {links.map((link) => (
          <a href={link.href} class="text-sm font-medium text-brand-muted hover:text-brand-charcoal">
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a href={withLocalePath('/catalogue', locale)} class="btn-secondary !px-4 !py-2">{uiText[locale].buttons.search}</a>
        <a href={siteData.primaryCTA.href} class="btn-primary">{siteData.primaryCTA.label}</a>
      </div>
    </div>

    <div class="md:hidden">
      <div class:list={['grid items-center gap-3', locale === 'ar' ? 'grid-cols-[44px_1fr_44px]' : 'grid-cols-[44px_1fr_44px]']}>
        <details class:list={['group relative', locale === 'ar' ? 'order-3' : 'order-1']}>
          <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-brand-line bg-white text-brand-charcoal marker:content-none">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
              <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
            </svg>
          </summary>
          <div class:list={[
            'absolute top-14 w-64 rounded-3xl border border-brand-line bg-white p-4 shadow-premium',
            locale === 'ar' ? 'left-0' : 'left-0'
          ]}>
            <div class="flex flex-col gap-2">
              {links.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'rounded-2xl px-3 py-2 text-sm font-medium text-brand-charcoal hover:bg-brand-bg',
                    locale === 'ar' ? 'text-right' : 'text-left'
                  ]}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </details>

        <a href={withLocalePath('/', locale)} class:list={['flex flex-col items-center justify-center text-center', 'order-2']}>
          <img src={brandAssets.logo} alt={`${siteData.brandName} logo`} class="h-12 w-12 rounded-full object-cover ring-1 ring-brand-gold/35" />
          <div class="mt-2 text-[11px] font-semibold uppercase tracking-brand text-brand-charcoal">{siteData.brandName}</div>
          <div class="text-[11px] text-brand-muted">{pageTitle || siteData.tagline}</div>
        </a>

        <a
          href={withLocalePath('/catalogue', locale)}
          class:list={[
            'flex h-11 w-11 items-center justify-center rounded-full border border-brand-line bg-white text-brand-charcoal',
            locale === 'ar' ? 'order-1' : 'order-3'
          ]}
          aria-label={uiText[locale].buttons.search}
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
            <circle cx="11" cy="11" r="6"></circle>
            <path d="M20 20l-4.2-4.2" stroke-linecap="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

---
import type { FAQItem } from '../lib/types';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props as Props;
---

<div class="grid gap-4">
  {items.map((item) => (
    <details class="card-shell p-5">
      <summary class="cursor-pointer list-none pr-8 text-base font-semibold text-brand-charcoal marker:content-none">
        {item.question}
      </summary>
      <p class="mt-3 text-sm leading-7 text-brand-muted">{item.answer}</p>
    </details>
  ))}
</div>

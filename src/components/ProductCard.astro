---
import type { Product } from '../lib/types';
import type { Locale } from '../lib/i18n';
import { getProductBadge, getProductCategoryLabel, getProductColors } from '../lib/product-source';

interface Props {
  product: Product;
  availableColors?: string[];
  locale?: Locale;
  basePath?: string;
  detailLabel?: string;
  colorsLabel?: string;
}

const {
  product,
  locale = 'fr',
  basePath = '',
  detailLabel = locale === 'ar' ? 'عرض المنتج' : 'Voir le produit',
  colorsLabel = locale === 'ar' ? 'الألوان' : 'Couleurs',
  availableColors = getProductColors(product, locale)
} = Astro.props as Props;

const title = locale === 'ar' ? product.baseNameAr || product.baseName || product.nameAr || product.name : product.baseName || product.name;
const imageAlt = locale === 'ar' ? product.nameAr || product.name : product.name;
const categoryLabel = getProductCategoryLabel(product, locale);
const badge = getProductBadge(product, locale);
const cardImages = product.images.slice(0, 2);
---

<article class="group overflow-hidden rounded-3xl border border-brand-line bg-white shadow-soft transition hover:-translate-y-1 hover:shadow-premium">
  <a href={`${basePath}/produit/${product.slug}`} class="block">
    <div class="relative overflow-hidden bg-brand-pearl p-3">
      {badge && (
        <span
          class:list={[
            'absolute left-5 top-5 z-10 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-soft',
            badge.tone === 'sale' ? 'bg-red-500' : badge.tone === 'best' ? 'bg-amber-500' : 'bg-brand-charcoal'
          ]}
        >
          {badge.label}
        </span>
      )}

      <div class:list={['grid gap-2', cardImages.length > 1 ? 'grid-cols-2' : 'grid-cols-1']}>
        {cardImages.map((image, index) => (
          <div class="overflow-hidden rounded-[1.25rem] bg-white">
            <img
              src={image}
              alt={`${imageAlt} ${index + 1}`}
              class="aspect-[4/5] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>
        ))}
      </div>
    </div>

    <div class="p-5">
      <div class="text-xs font-semibold uppercase tracking-brand text-brand-muted">{categoryLabel}</div>
      <h3 class="mt-2 text-base font-semibold text-brand-charcoal sm:text-lg">{title}</h3>

      {availableColors.length > 0 && (
        <p class="mt-2 text-sm text-brand-muted">
          {colorsLabel}: {availableColors.join(' / ')}
        </p>
      )}

      <div class="mt-4 flex items-end justify-between gap-4">
        <div>
          {product.oldPrice && (
            <div dir="ltr" class="inline-block whitespace-nowrap text-sm text-brand-muted line-through">
              {product.oldPrice}
            </div>
          )}
          <div dir="ltr" class="inline-block whitespace-nowrap text-lg font-semibold text-brand-charcoal">
            {product.price}
          </div>
        </div>
        <span class="inline-flex items-center rounded-full bg-brand-charcoal px-4 py-2 text-sm font-semibold text-white">
          {detailLabel}
        </span>
      </div>
    </div>
  </a>
</article>

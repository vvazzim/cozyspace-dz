---
import type { Product } from '../lib/types';
import type { Locale } from '../lib/i18n';

interface Props {
  product: Product;
  availableColors?: string[];
  locale?: Locale;
  basePath?: string;
  detailLabel?: string;
  colorsLabel?: string;
}

const {
  product,
  locale = 'fr',
  basePath = '',
  detailLabel = 'Voir le detail',
  colorsLabel = 'Couleurs',
  availableColors = locale === 'ar'
    ? product.colorAr
      ? [product.colorAr]
      : product.color
        ? [product.color]
        : []
    : product.color
      ? [product.color]
      : []
} = Astro.props as Props;
const title = locale === 'ar' ? product.baseNameAr || product.baseName || product.nameAr || product.name : product.baseName || product.name;
const collection = locale === 'ar' ? product.collectionAr || product.collection : product.collection;
const description = locale === 'ar' ? product.shortDescriptionAr || product.shortDescription : product.shortDescription;
const imageAlt = locale === 'ar' ? product.nameAr || product.name : product.name;
---

<article class="group overflow-hidden rounded-3xl border border-brand-line bg-white shadow-soft transition hover:-translate-y-1 hover:shadow-premium">
  <a href={`${basePath}/produit/${product.slug}`} class="block">
    <div class="overflow-hidden bg-brand-pearl">
      <img src={product.images[0]} alt={imageAlt} class="aspect-[4/5] w-full object-cover transition duration-300 group-hover:scale-[1.02]" loading="lazy" />
    </div>

    <div class="p-5">
      <div class="text-xs font-semibold uppercase tracking-brand text-brand-muted">{collection}</div>
      <h3 class="mt-2 text-lg font-semibold text-brand-charcoal">{title}</h3>
      <p class="mt-2 text-sm leading-7 text-brand-muted">{description}</p>
      {availableColors.length > 0 && (
        <p class="mt-3 text-sm font-medium text-brand-charcoal">{colorsLabel}: {availableColors.join(' / ')}</p>
      )}

      <div class="mt-4 flex items-end justify-between gap-4">
        <div>
          {product.oldPrice && <div class="text-sm text-brand-muted line-through">{product.oldPrice}</div>}
          <div class="text-base font-semibold text-brand-charcoal">{product.price}</div>
        </div>
        <span class="text-sm font-medium text-brand-gold">{detailLabel}</span>
      </div>
    </div>
  </a>
</article>

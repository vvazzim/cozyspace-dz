---
import { type Locale, uiText } from '../lib/i18n';

interface Props {
  productName: string;
  productSlug: string;
  productPrice?: string;
  embedded?: boolean;
  locale?: Locale;
}

const { productName, productSlug, productPrice = '', embedded = false, locale = 'fr' } = Astro.props;
const labels = uiText[locale].order;
const googleScriptUrl =
  import.meta.env.PUBLIC_GOOGLE_SCRIPT_URL ||
  'https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec';
---

<div
  id="order-modal"
  class:list={[
    embedded ? 'mt-8' : 'fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm',
    embedded ? '' : ''
  ]}
>
  <div class:list={[embedded ? '' : 'flex min-h-screen items-center justify-center p-4']}>
    <div class:list={['card-shell bg-white p-6', embedded ? 'w-full' : 'w-full max-w-md']}>
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-brand-charcoal">{labels.title} {productName}</h3>
        {!embedded && (
          <button id="close-modal" class="text-brand-muted hover:text-brand-charcoal">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        )}
      </div>

      <form
        id="order-form"
        action={googleScriptUrl}
        method="GET"
        target="order-submit-frame"
        class="mt-6 space-y-4"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="firstName" class="block text-sm font-medium text-brand-charcoal">{labels.firstName}</label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              class="mt-1 block w-full rounded-lg border border-brand-line px-3 py-2 text-sm focus:border-brand-gold focus:outline-none"
            />
          </div>
          <div>
            <label for="lastName" class="block text-sm font-medium text-brand-charcoal">{labels.lastName}</label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              class="mt-1 block w-full rounded-lg border border-brand-line px-3 py-2 text-sm focus:border-brand-gold focus:outline-none"
            />
          </div>
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-brand-charcoal">{labels.phone}</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            class="mt-1 block w-full rounded-lg border border-brand-line px-3 py-2 text-sm focus:border-brand-gold focus:outline-none"
          />
        </div>

        <div>
          <label for="quantity" class="block text-sm font-medium text-brand-charcoal">{labels.quantity}</label>
          <input
            type="number"
            id="quantity"
            name="quantity"
            min="1"
            value="1"
            required
            class="mt-1 block w-full rounded-lg border border-brand-line px-3 py-2 text-sm focus:border-brand-gold focus:outline-none"
          />
        </div>

        <div>
          <label for="address" class="block text-sm font-medium text-brand-charcoal">{labels.address}</label>
          <textarea
            id="address"
            name="address"
            rows="3"
            required
            class="mt-1 block w-full rounded-lg border border-brand-line px-3 py-2 text-sm focus:border-brand-gold focus:outline-none"
            placeholder={labels.addressPlaceholder}
          ></textarea>
        </div>

        <input type="hidden" name="product" value={productName} />
        <input type="hidden" name="productSlug" value={productSlug} />
        <input type="hidden" name="price" value={productPrice} />

        <div class="flex gap-3 pt-4">
          <button
            type="submit"
            class="flex-1 rounded-full bg-brand-charcoal px-6 py-3 text-sm font-semibold text-white hover:bg-brand-ink focus:outline-none focus:ring-2 focus:ring-brand-gold focus:ring-offset-2"
          >
            {labels.submit}
          </button>
          <button
            type="button"
            id="cancel-order"
            class:list={[
              'rounded-full border border-brand-line bg-white px-6 py-3 text-sm font-semibold text-brand-charcoal hover:bg-brand-bg focus:outline-none focus:ring-2 focus:ring-brand-gold focus:ring-offset-2',
              embedded ? 'hidden' : ''
            ]}
          >
            {labels.cancel}
          </button>
        </div>
      </form>

      <div id="success-message" class="mt-4 hidden rounded-lg bg-green-50 p-4 text-sm text-green-800">
        {labels.success}
      </div>

      <div id="error-message" class="mt-4 hidden rounded-lg bg-red-50 p-4 text-sm text-red-800">
        {labels.error}
      </div>
    </div>
  </div>
</div>

<iframe name="order-submit-frame" class="hidden" title="Soumission de commande"></iframe>

<script>
  const modal = document.getElementById('order-modal');
  const closeBtn = document.getElementById('close-modal');
  const cancelBtn = document.getElementById('cancel-order');
  const form = document.getElementById('order-form');
  const successMessage = document.getElementById('success-message');
  const errorMessage = document.getElementById('error-message');
  const submitButton = form?.querySelector('button[type="submit"]');
  const isEmbedded = modal?.classList.contains('mt-8');

  window.openOrderModal = () => {
    if (!modal) return;
    if (modal.classList.contains('mt-8')) return;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (!modal || !form || !successMessage || !errorMessage) return;
    if (!isEmbedded) {
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
    }
    form.reset();
    successMessage.classList.add('hidden');
    errorMessage.classList.add('hidden');
  };

  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form || !successMessage || !errorMessage || !submitButton) return;

    try {
      submitButton.setAttribute('disabled', 'disabled');
      form.submit();
      successMessage.classList.remove('hidden');
      errorMessage.classList.add('hidden');
      submitButton.removeAttribute('disabled');

      setTimeout(() => {
        closeModal();
      }, 3000);
    } catch (error) {
      console.error('Erreur:', error);
      submitButton.removeAttribute('disabled');
      successMessage.classList.add('hidden');
      errorMessage.classList.remove('hidden');
    }
  });
</script>

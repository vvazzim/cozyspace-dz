---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import OrderForm from '../../components/OrderForm.astro';
import { getProductColors, getProducts, getSimilarProducts } from '../../lib/product-source';

export async function getStaticPaths() {
  const products = await getProducts();

  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product, products }
  }));
}

const { product, products } = Astro.props;
const displayName = product.baseName || product.name;
const similarProducts = getSimilarProducts(products, product);
const colors = getProductColors(product, 'fr');
const galleryId = `product-gallery-${product.slug}`;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: displayName,
  description: product.shortDescription,
  image: product.images,
  category: product.category,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'DZD',
    price: product.price.replace(/[^\d]/g, ''),
    availability: 'https://schema.org/InStock'
  }
};
---

<MainLayout title={product.name} description={product.shortDescription} image={product.images[0]}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <section class="section-shell">
    <div class="container-shell">
      <div class="mb-8">
        <div class="text-sm font-semibold uppercase tracking-brand text-brand-muted">{product.collection}</div>
        <h1 class="mt-3 text-3xl font-semibold text-brand-charcoal sm:text-5xl">{displayName}</h1>
      </div>

      <div class="grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-start">
        <div class="card-shell overflow-hidden p-4 sm:p-6">
          <div class="relative" data-product-gallery={galleryId}>
            <div
              id={galleryId}
              class="product-gallery-track flex snap-x snap-mandatory overflow-x-auto scroll-smooth rounded-[1.5rem]"
              dir="ltr"
            >
              {product.images.map((image, index) => (
                <figure class="product-gallery-slide w-full min-w-full overflow-hidden bg-brand-pearl">
                  <img
                    src={image}
                    alt={`${product.name} ${index + 1}`}
                    class="aspect-[4/5] w-full object-cover"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    referrerpolicy="no-referrer"
                  />
                </figure>
              ))}
            </div>

            {product.images.length > 1 && (
              <>
                <button
                  type="button"
                  class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full border border-brand-line bg-white/90 px-3 py-2 text-sm font-semibold text-brand-charcoal shadow-soft hover:border-brand-gold"
                  data-gallery-prev={galleryId}
                  aria-label="Image precedente"
                >
                  ←
                </button>
                <button
                  type="button"
                  class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full border border-brand-line bg-white/90 px-3 py-2 text-sm font-semibold text-brand-charcoal shadow-soft hover:border-brand-gold"
                  data-gallery-next={galleryId}
                  aria-label="Image suivante"
                >
                  →
                </button>
              </>
            )}
          </div>

          {product.images.length > 1 && (
            <div class="mt-4 flex flex-wrap justify-center gap-2" data-gallery-dots={galleryId}>
              {product.images.map((image, index) => (
                <button
                  type="button"
                  class="product-gallery-dot h-2.5 w-2.5 rounded-full bg-brand-line"
                  data-gallery-dot={galleryId}
                  data-gallery-index={index}
                  aria-label={`Afficher l'image ${index + 1}`}
                  aria-current={index === 0 ? 'true' : 'false'}
                ></button>
              ))}
            </div>
          )}
        </div>

        <div>
          <p class="mt-4 text-sm leading-7 text-brand-muted sm:text-base">{product.shortDescription}</p>

          <div class="mt-6 flex items-end gap-4">
            <div class="text-2xl font-semibold text-brand-charcoal">{product.price}</div>
            {product.oldPrice && <div class="text-sm text-brand-muted line-through">{product.oldPrice}</div>}
          </div>

          <div class="mt-6 rounded-3xl border border-brand-line bg-white p-5">
            <div class="text-sm font-semibold text-brand-charcoal">Points forts</div>
            <ul class="mt-4 grid gap-3 text-sm text-brand-muted">
              {product.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 h-2.5 w-2.5 rounded-full bg-brand-gold"></span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-6 rounded-3xl border border-brand-line bg-brand-bg p-5">
            <div class="text-sm font-medium text-brand-charcoal">Disponibilite</div>
            <p class="mt-2 text-sm leading-7 text-brand-muted">{product.availability}</p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/catalogue" class="btn-secondary">Visiter la boutique</a>
            <a href="/contact" class="btn-secondary">Contacter la marque</a>
          </div>

          <OrderForm
            productName={product.name}
            productSlug={product.slug}
            productPrice={product.price}
            colors={colors}
            embedded={true}
          />
        </div>
      </div>

      {similarProducts.length > 0 && (
        <div class="mt-20">
          <h2 class="text-2xl font-semibold text-brand-charcoal">Produits similaires</h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
            {similarProducts.map((item) => <ProductCard product={item} />)}
          </div>
        </div>
      )}
    </div>
  </section>
  <script is:inline>
    (() => {
      const setupGallery = (root) => {
        const galleryId = root.getAttribute('data-product-gallery');
        if (!galleryId) return;

        const track = document.getElementById(galleryId);
        if (!track) return;

        const dots = Array.from(document.querySelectorAll(`[data-gallery-dot="${galleryId}"]`));
        const prevButton = document.querySelector(`[data-gallery-prev="${galleryId}"]`);
        const nextButton = document.querySelector(`[data-gallery-next="${galleryId}"]`);

        const getIndex = () => {
          const width = track.clientWidth || 1;
          return Math.round(track.scrollLeft / width);
        };

        const updateDots = () => {
          const activeIndex = getIndex();
          dots.forEach((dot, index) => {
            dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
          });
        };

        const scrollToIndex = (index) => {
          track.scrollTo({ left: track.clientWidth * index, behavior: 'smooth' });
        };

        prevButton?.addEventListener('click', () => {
          scrollToIndex(Math.max(0, getIndex() - 1));
        });

        nextButton?.addEventListener('click', () => {
          scrollToIndex(Math.min(dots.length - 1, getIndex() + 1));
        });

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => scrollToIndex(index));
        });

        track.addEventListener('scroll', () => {
          window.requestAnimationFrame(updateDots);
        });

        window.addEventListener('resize', updateDots);
        updateDots();
      };

      document.querySelectorAll('[data-product-gallery]').forEach(setupGallery);
    })();
  </script>
</MainLayout>

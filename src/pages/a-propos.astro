---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CTASection from '../components/CTASection.astro';
import { aboutCopy, brandAssets, siteData } from '../data/site';
---

<MainLayout title="A propos" description={aboutCopy.intro}>
  <section class="section-shell">
    <div class="container-shell">
      <div class="grid items-center gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="card-shell overflow-hidden p-5 sm:p-6">
          <img src={brandAssets.banner} alt="Univers de marque Cozy Space" class="w-full rounded-[1.5rem] object-cover shadow-soft" />
        </div>

        <div>
          <SectionTitle
            eyebrow="Univers de marque"
            title="Une boutique douce, utile et facile a faire evoluer"
            copy={aboutCopy.intro}
          />

          <p class="mt-6 max-w-2xl text-sm leading-7 text-brand-muted sm:text-base">
            {aboutCopy.mission}
          </p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <article class="card-shell p-5">
              <h3 class="text-lg font-semibold text-brand-charcoal">Esprit quotidien</h3>
              <p class="mt-2 text-sm leading-7 text-brand-muted">Des objets utiles, faciles a integrer dans la maison, les routines ou les petites attentions du quotidien.</p>
            </article>
            <article class="card-shell p-5">
              <h3 class="text-lg font-semibold text-brand-charcoal">Direction visuelle douce</h3>
              <p class="mt-2 text-sm leading-7 text-brand-muted">Le logo, les teintes grises, le noir et le dore composent un univers sobre, feminin-universel et rassurant.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Le template est pret a etre enrichi avec les vraies collections"
    copy="Les categories, les produits, les prix, les visuels et les informations de contact peuvent etre remplaces rapidement depuis les fichiers de donnees centralises."
  />
</MainLayout>

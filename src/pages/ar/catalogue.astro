---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categories } from '../../data/categories';
import { getAvailableColors, getCatalogProducts, getProducts } from '../../lib/product-source';

const products = await getProducts();
const catalogProducts = getCatalogProducts(products);
---

<MainLayout
  locale="ar"
  title="Ø§Ù„ÙƒØªØ§Ù„ÙˆØ¬"
  description="ÙƒØªØ§Ù„ÙˆØ¬ Cozy Space Ø¨Ø§Ù„Ø¹Ø±Ø¨ÙŠØ© Ù…Ø¹ Ù…Ø±Ø§ÙŠØ§ Ù…Ø¶ÙŠØ¦Ø© ÙˆØ®ÙŠØ§Ø±Ø§Øª Ø£Ù„ÙˆØ§Ù† ÙˆØ§Ø¶Ø­Ø©."
>
  <section class="section-shell">
    <div class="container-shell">
      <SectionTitle
        eyebrow="Ø§Ù„ÙƒØªØ§Ù„ÙˆØ¬"
        title="Ù…Ø±Ø§ÙŠØ§ Ù…Ø¶ÙŠØ¦Ø©"
        copy="Ù…Ø¬Ù…ÙˆØ¹Ø© Ù…Ù† Ø§Ù„Ù…Ø±Ø§ÙŠØ§ Ø§Ù„Ù…Ø¶ÙŠØ¦Ø© Ø¨ØªØµÙ…ÙŠÙ… Ø¹ØµØ±ÙŠ ÙˆØ¥Ø¶Ø§Ø¡Ø© LED Ù…Ø¯Ù…Ø¬Ø©ØŒ Ù…Ù†Ø§Ø³Ø¨Ø© Ù„Ù„Ø­Ù…Ø§Ù… Ø£Ùˆ Ø±ÙƒÙ† Ø§Ù„ØªØ²ÙŠÙŠÙ†."
      />

      <div class="mt-8 flex flex-wrap gap-3" id="filters">
        <button class="rounded-full border border-brand-gold/40 bg-white px-4 py-2 text-sm font-medium text-brand-charcoal" data-filter="all">Ø¹Ø±Ø¶ Ø§Ù„ÙƒÙ„</button>
        {categories.map((category) => (
          <button id={category.slug} class="rounded-full border border-brand-line bg-white/80 px-4 py-2 text-sm font-medium text-brand-muted hover:text-brand-charcoal" data-filter={category.name}>
            {category.nameAr || category.name}
          </button>
        ))}
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4" id="catalog-grid">
        {catalogProducts.map((product) => (
          <div data-category={product.category}>
            <ProductCard
              product={product}
              locale="ar"
              basePath="/ar"
              availableColors={getAvailableColors(products, product.slug, product.variantGroup, 'ar')}
              detailLabel="Ø¹Ø±Ø¶ Ø§Ù„ØªÙØ§ØµÙŠÙ„"
              colorsLabel="Ø§Ù„Ø£Ù„ÙˆØ§Ù†"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const buttons = Array.from(document.querySelectorAll('[data-filter]'));
    const items = Array.from(document.querySelectorAll('[data-category]'));

    function setActive(button) {
      buttons.forEach((btn) => {
        btn.classList.remove('border-brand-gold/40', 'text-brand-charcoal');
        btn.classList.add('border-brand-line', 'text-brand-muted');
      });
      button.classList.remove('border-brand-line', 'text-brand-muted');
      button.classList.add('border-brand-gold/40', 'text-brand-charcoal');
    }

    function applyFilter(value) {
      items.forEach((item) => {
        const match = value === 'all' || item.getAttribute('data-category') === value;
        item.style.display = match ? '' : 'none';
      });
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const value = button.getAttribute('data-filter') || 'all';
        setActive(button);
        applyFilter(value);
      });
    });

    const hash = window.location.hash.replace('#', '');
    const initialButton = buttons.find((button) => button.id === hash);
    if (initialButton) {
      setActive(initialButton);
      applyFilter(initialButton.getAttribute('data-filter') || 'all');
    }
  </script>
</MainLayout>

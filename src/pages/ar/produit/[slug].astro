---
import MainLayout from '../../../layouts/MainLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import OrderForm from '../../../components/OrderForm.astro';
import { products } from '../../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const displayName = product.baseNameAr || product.baseName || product.nameAr || product.name;
const productName = product.nameAr || product.name;
const collection = product.collectionAr || product.collection;
const description = product.shortDescriptionAr || product.shortDescription;
const availability = product.availabilityAr || product.availability;
const features = product.featuresAr || product.features;
const variants = products.filter((item) =>
  product.variantGroup ? item.variantGroup === product.variantGroup : item.slug === product.slug
);
const similarProducts = products
  .filter(
    (item) =>
      item.category === product.category &&
      item.slug !== product.slug &&
      item.variantGroup !== product.variantGroup
  )
  .filter(
    (item, index, list) =>
      index === list.findIndex((entry) => (entry.variantGroup || entry.slug) === (item.variantGroup || item.slug))
  )
  .slice(0, 4);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: displayName,
  description,
  image: product.images,
  category: product.category,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'DZD',
    price: product.price.replace(/[^\d]/g, ''),
    availability: 'https://schema.org/InStock'
  }
};
---

<MainLayout locale="ar" title={displayName} description={description} image={product.images[0]}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <section class="section-shell">
    <div class="container-shell">
      <div class="mb-8">
        <div class="text-sm font-semibold uppercase tracking-brand text-brand-muted">{collection}</div>
        <h1 class="mt-3 text-3xl font-semibold text-brand-charcoal sm:text-5xl">{displayName}</h1>
      </div>

      <div class="grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-start">
        <div class="card-shell overflow-hidden p-4 sm:p-6">
          <img src={product.images[0]} alt={productName} class="w-full rounded-[1.5rem] bg-brand-pearl object-cover" />
        </div>

        <div>
          {variants.length > 1 && (
            <div class="rounded-3xl border border-brand-line bg-white p-5">
              <div class="text-sm font-semibold text-brand-charcoal">اللون</div>
              <div class="mt-4 flex flex-wrap gap-3">
                {variants.map((variant) => {
                  const isActive = variant.slug === product.slug;

                  return (
                    <a
                      href={`/ar/produit/${variant.slug}`}
                      class:list={[
                        'rounded-full border px-4 py-2 text-sm font-semibold transition',
                        isActive
                          ? 'border-brand-charcoal bg-brand-charcoal text-white'
                          : 'border-brand-line bg-white text-brand-charcoal hover:border-brand-gold'
                      ]}
                    >
                      {variant.colorAr || variant.color || variant.nameAr || variant.name}
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          <p class="mt-4 text-sm leading-7 text-brand-muted sm:text-base">{description}</p>

          <div class="mt-6 flex items-end gap-4">
            <div class="text-2xl font-semibold text-brand-charcoal">{product.price}</div>
            {product.oldPrice && <div class="text-sm text-brand-muted line-through">{product.oldPrice}</div>}
          </div>

          <div class="mt-6 rounded-3xl border border-brand-line bg-white p-5">
            <div class="text-sm font-semibold text-brand-charcoal">المميزات</div>
            <ul class="mt-4 grid gap-3 text-sm text-brand-muted">
              {features.map((feature) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 h-2.5 w-2.5 rounded-full bg-brand-gold"></span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-6 rounded-3xl border border-brand-line bg-brand-bg p-5">
            <div class="text-sm font-medium text-brand-charcoal">التوفر</div>
            <p class="mt-2 text-sm leading-7 text-brand-muted">{availability}</p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/ar/catalogue" class="btn-secondary">زيارة المتجر</a>
            <a href="/ar/contact" class="btn-secondary">تواصل مع العلامة</a>
          </div>

          <OrderForm
            productName={productName}
            productSlug={product.slug}
            productPrice={product.price}
            embedded={true}
            locale="ar"
          />
        </div>
      </div>

      {similarProducts.length > 0 && (
        <div class="mt-20">
          <h2 class="text-2xl font-semibold text-brand-charcoal">منتجات مشابهة</h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
            {similarProducts.map((item) => (
              <ProductCard
                product={item}
                locale="ar"
                basePath="/ar"
                detailLabel="عرض التفاصيل"
                colorsLabel="الألوان"
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</MainLayout>
